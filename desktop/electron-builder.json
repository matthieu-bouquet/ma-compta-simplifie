{
  "appId": "com.macomptasimplifie.desktop",
  "productName": "MaComptaSimplifie",
  "executableName": "MaComptaSimplifie",
  "electronVersion": "42.0.0-beta.8",
  "directories": {
    "output": "../dist-desktop"
  },
  "asar": true,
  "asarUnpack": ["**/*.node", "**/*.dylib", "**/*.so"],
  "files": ["**/*"],
  "extraFiles": [{ "from": "assets", "to": "assets" }],
  "extraResources": [
    { "from": "../.next/standalone", "to": "app" },
    { "from": "../.next/standalone/node_modules", "to": "app/node_modules" },
    { "from": "../.next/static", "to": "app/.next/static" },
    { "from": "../public", "to": "app/public" },
    { "from": "../prisma", "to": "app/prisma" }
  ],
  "mac": {
    "target": ["dmg"],
    "icon": "assets/icon.icns",
    "identity": null,
    "extendInfo": {
      "CFBundleDisplayName": "Ma Compta Simplifié"
    }
  },
  "win": { "target": ["nsis"], "icon": "assets/icon.ico" },
  "linux": { "target": ["AppImage"], "icon": "assets/icon.png" }
}

