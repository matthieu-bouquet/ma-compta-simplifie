{
  "name": "accouting-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "icons:electron": "node scripts/generate-electron-icons.mjs",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node scripts/test/run-unit-tests.mjs",
    "test:e2e": "DATABASE_URL=file:./.tmp/e2e.db DOCUMENTS_DIR=./.tmp/documents playwright test",
    "desktop:dev": "concurrently -k \"tsc -p desktop/electron/tsconfig.json --watch\" \"next dev -p 3000\" \"wait-on http://localhost:3000 && wait-on desktop/dist-electron/main.js && ELECTRON_NEXT_URL=http://localhost:3000 electron desktop/dist-electron/main.js\"",
    "desktop:build": "node scripts/build-template-db.mjs && next build && node scripts/fix-standalone-symlinks.mjs && tsc -p desktop/electron/tsconfig.json",
    "desktop:dist": "npm run desktop:build && electron-builder --projectDir desktop --config electron-builder.json"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/react-datepicker": "^6.2.0",
    "archiver": "^7.0.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.4",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "electron": "41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^5.22.0",
    "to-ico": "^1.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "author": "Ma Compta Simplifié",
  "license": "UNLICENSED",
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
