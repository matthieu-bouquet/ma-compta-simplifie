generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Association {
  id         String   @id @default(uuid())
  name       String
  siret      String?  @unique
  address    String?
  postalCode String?
  city       String?
  email      String?
  phone      String?
  legalFormCode  String?
  legalFormOther String?
  chartTemplateId String?
  chartTemplate   ChartTemplate? @relation(fields: [chartTemplateId], references: [id], onDelete: SetNull)
  /// Subject to French VAT (assujetti à la TVA).
  vatLiable  Boolean  @default(false)
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fiscalYears   FiscalYear[]
  budgets       Budget[]
  counterparties Counterparty[]
  recurringExpenseTemplates RecurringExpenseTemplate[]
}

// Third parties (suppliers / customers) scoped to the association (UI: Paramètres → Fournisseurs et clients).
model Counterparty {
  id             String      @id @default(uuid())
  associationId  String
  association    Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  // SQLite: use string constants SUPPLIER | CUSTOMER at application layer
  kind           String
  name           String

  entries Entry[]
  recurringExpenseTemplates RecurringExpenseTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([associationId, kind])
}

/// Quick-entry template (UI: dépense courante / modèle de saisie), scoped to association.
model RecurringExpenseTemplate {
  id            String      @id @default(uuid())
  associationId String
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  title         String
  operationType String // DEPENSE | RECETTE | TRANSFERT
  /// Null = amount entered at each use (quick-entry scaffold).
  amountCents   Int?

  counterpartyId String?
  counterparty   Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)

  operationAccountNumber String
  treasuryAccountNumber  String?
  /// Preset pack code (e.g. CORE_ASSOCIATION); null = user-created template.
  packCode               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([associationId, title])
  @@unique([associationId, title, operationType])
}

model Budget {
  id            String      @id @default(uuid())
  associationId String
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  name  String
  notes String?

  // Reference snapshot (informational only) when prefilled
  sourceFiscalYearId       String?
  sourceCoefficientPercent Int? // ex: 110 = +10%

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines BudgetLine[]

  @@index([associationId, updatedAt])
}

model BudgetLine {
  id       String @id @default(uuid())
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  accountNumber String
  accountName   String
  amountCents   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, accountNumber])
  @@index([budgetId])
}

model ChartTemplate {
  id        String   @id @default(uuid())
  code      String   @unique // ex: ASSOCIATION, TPE
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  ChartTemplateAccount[]
  associations Association[]
}

model ChartTemplateAccount {
  id              String        @id @default(uuid())
  chartTemplateId String
  chartTemplate   ChartTemplate @relation(fields: [chartTemplateId], references: [id], onDelete: Cascade)

  number    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chartTemplateId, number])
  @@index([chartTemplateId, number])
}

model FiscalYear {
  id            String   @id @default(uuid())
  startDate     DateTime
  endDate       DateTime
  status        String   // "OPEN" or "CLOSED"
  associationId String
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  accounts   Account[]
  entries    Entry[]
  documents  Document[]
  inKindContributions InKindContribution[]

  @@unique([associationId, startDate, endDate])
}

model Journal {
  id      String  @id @default(uuid())
  code    String  @unique // BQ, AC, VE, OD
  name    String
  entries Entry[]
}

model Account {
  id           String     @id @default(uuid())
  number       String
  name         String
  fiscalYearId String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  lines EntryLine[]

  @@unique([number, fiscalYearId])
}

model Entry {
  id              String     @id @default(uuid())
  date            DateTime
  description     String
  journalId       String
  journal         Journal    @relation(fields: [journalId], references: [id])
  fiscalYearId    String
  fiscalYear      FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  lines           EntryLine[]

  counterpartyId String?
  counterparty   Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)

  referenceNumber   String?
  referenceSequence Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([fiscalYearId, journalId, date])
  @@index([counterpartyId])
}

model EntryLine {
  id          String  @id @default(uuid())
  entryId     String
  entry       Entry   @relation(fields: [entryId], references: [id], onDelete: Cascade)

  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountNumber String
  accountName   String

  debitCents  Int @default(0)
  creditCents Int @default(0)

  documents  DocumentEntryLine[]

  // Internal allocation links (e.g. supplier payable 401 credit lines allocated by 401 debit settlements).
  payableAllocations   CounterpartySettlementAllocation[] @relation("PayableLineAllocations")
  settlementAllocations CounterpartySettlementAllocation[] @relation("SettlementLineAllocations")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model CounterpartySettlementAllocation {
  id String @id @default(uuid())

  // 401/411 line representing the payable/receivable to be settled (typically credit for 401, debit for 411).
  payableLineId String
  payableLine   EntryLine @relation("PayableLineAllocations", fields: [payableLineId], references: [id], onDelete: Cascade)

  // 401/411 line representing the settlement movement (typically debit for 401, credit for 411).
  settlementLineId String
  settlementLine   EntryLine @relation("SettlementLineAllocations", fields: [settlementLineId], references: [id], onDelete: Cascade)

  amountCents Int

  createdAt DateTime @default(now())

  @@index([payableLineId])
  @@index([settlementLineId])
  @@unique([payableLineId, settlementLineId])
}

model JournalSequence {
  id           String   @id @default(uuid())
  fiscalYearId String
  journalId    String
  nextNumber   Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([fiscalYearId, journalId])
  @@index([fiscalYearId])
}

model AuditEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  associationId String?
  fiscalYearId  String?

  actor      String? // no user system yet (ex: associationId, "system")
  action     String  // ex: ENTRY_CREATE, ENTRY_REVERSE, FISCAL_YEAR_CLOSE, DOCUMENT_UPLOAD
  entityType String  // ex: Entry, Document, FiscalYear, Account
  entityId   String?

  data       String? // JSON string (SQLite)

  @@index([associationId, createdAt])
  @@index([fiscalYearId, createdAt])
  @@index([entityType, entityId])
}

model Document {
  id           String   @id @default(uuid())
  fiscalYearId String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  sha256       String?

  relativePath String
  uploadedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lines DocumentEntryLine[]
  inKindContributions InKindContribution[]

  @@index([fiscalYearId, uploadedAt])
  @@unique([fiscalYearId, storedName])
}

model DocumentEntryLine {
  id          String    @id @default(uuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entryLineId String
  entryLine   EntryLine @relation(fields: [entryLineId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([documentId, entryLineId])
  @@index([entryLineId])
  @@index([documentId])
}

model InKindContribution {
  id String @id @default(uuid())

  associationId String
  fiscalYearId  String
  fiscalYear    FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  // SQLite connector in this repo does not support Prisma enums.
  // Values are validated at the application layer.
  kind String

  date DateTime
  description String
  contributorName String?

  quantityMilliUnits Int
  unit String

  unitValueCents  Int?
  totalValueCents Int
  valuationMethod String

  meetsAnc2112Essential Boolean
  meetsAnc2112Measurable Boolean

  isRecorded Boolean
  entryId    String?

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([associationId, fiscalYearId, kind, date])
  @@index([fiscalYearId, date])
  @@index([entryId])
  @@index([documentId])
}
